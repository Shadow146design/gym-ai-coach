# Base de donnees Postgres (Render te la fournit automatiquement si tu crees
# un service "PostgreSQL" sur Render -> copie la "Internal Database URL")
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cle API Groq (gratuite, sans CB) -> https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Modele utilise pour generer les programmes (gratuit sur Groq)
GROQ_MODEL=llama-3.3-70b-versatile

# Chaine secrete random pour signer les sessions (genere-en une avec :
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=change_moi_en_une_chaine_aleatoire_longue

# Port local (Render fixe automatiquement sa propre variable PORT en prod)
PORT=3000

# Stripe (paiement Premium uniquement -> https://dashboard.stripe.com/apikeys)
# Les coaches humains fixent leur propre tarif (coach_profiles.price_monthly),
# il n'y a plus de plan Stripe fixe "Coach" cote plateforme.
STRIPE_SECRET_KEY=<remplace-par-ta-cle-secrete-stripe>
STRIPE_WEBHOOK_SECRET=<remplace-par-ton-secret-webhook-stripe>
STRIPE_PREMIUM_PRICE_ID=<remplace-par-l-id-du-price-premium>

# Google OAuth (connexion "Se connecter avec Google") -> https://console.cloud.google.com/apis/credentials
# Sans ces 2 variables, le bouton Google redirige simplement vers /?error=google_not_configured.
# A definir aussi bien en local (.env) que sur Render (Environment).
GOOGLE_CLIENT_ID=<remplace-par-ton-client-id-google>
GOOGLE_CLIENT_SECRET=<remplace-par-ton-client-secret-google>
# Optionnel : par defaut le code utilise https://gym-ai-coach-1wls.onrender.com/auth/google/callback
GOOGLE_REDIRECT_URI=https://gym-ai-coach-1wls.onrender.com/auth/google/callback

# Notifications push (Web Push API) -> genere une paire de cles avec :
# node -e "console.log(require('web-push').generateVAPIDKeys())"
# Sans ces 3 variables, les notifications push restent silencieusement desactivees.
VAPID_PUBLIC_KEY=<remplace-par-ta-cle-publique-vapid>
VAPID_PRIVATE_KEY=<remplace-par-ta-cle-privee-vapid>
VAPID_SUBJECT=mailto:ton-email@exemple.com
