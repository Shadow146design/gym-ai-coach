# Base de donnees Postgres (Render te la fournit automatiquement si tu crees
# un service "PostgreSQL" sur Render -> copie la "Internal Database URL")
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cle API Groq (gratuite, sans CB) -> https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Modele utilise pour generer les programmes (gratuit sur Groq)
GROQ_MODEL=llama-3.3-70b-versatile

# Chaine secrete random pour signer les sessions (genere-en une avec :
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=change_moi_en_une_chaine_aleatoire_longue

# Port local (Render fixe automatiquement sa propre variable PORT en prod)
PORT=3000

# Stripe (paiements Premium / Coach) -> https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=<remplace-par-ta-cle-secrete-stripe>
STRIPE_WEBHOOK_SECRET=<remplace-par-ton-secret-webhook-stripe>
STRIPE_PREMIUM_PRICE_ID=<remplace-par-l-id-du-price-premium>
STRIPE_COACH_PRICE_ID=<remplace-par-l-id-du-price-coach>
